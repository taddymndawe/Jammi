# ─────────────────────────────────────────────────────────────
# jammi · environment variables (copy to .env, never commit .env)
# ─────────────────────────────────────────────────────────────

# ── Business layer (Node/Express) ────────────────────────────
PORT=4000
PYTHON_BIN=python3
# Shared secret that protects POST /api/admin/rescrape.
# Leave unset to disable the admin endpoint entirely.
ADMIN_TOKEN=

# ── Firebase (shared by backend + data layer) ────────────────
# Provide ONE of the following. The JSON-string form is what the
# GitHub Action injects; the path form is convenient locally.
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json
FIRESTORE_COLLECTION=timetables

# ── Data layer · source (Python pipeline) ────────────────────
# The page we scrape for timetable PDF links.
UCT_TIMETABLE_URL=https://uct.ac.za/students/services-transport-parking-uct-shuttle/route-maps-timetables
# Optional hard override: comma-separated direct PDF URLs (skips discovery).
UCT_PDF_URLS=
REQUEST_TIMEOUT=30

# ── Data layer · LLM formatter ───────────────────────────────
# The model only reshapes extracted text into JSON; it never invents times.
ANTHROPIC_API_KEY=
JAMMI_LLM_MODEL=claude-sonnet-4-6
JAMMI_LLM_MAX_TOKENS=8000

# Set to 1 to parse without writing to Firestore.
JAMMI_DRY_RUN=0

# ── Frontend (presentation/public/js/firebase-config.js) ─────
# NOTE: the web app's Firebase config is PUBLIC by design and lives in
# firebase-config.js, not here. Replace the REPLACE_* placeholders there
# with your project's web config to leave preview mode.
