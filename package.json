{
  "name": "jammi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "jammi — the fastest way for UCT students to catch the Jammie. Premium, minimalist, one click away.",
  "main": "business/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node business/server.js",
    "dev": "node --watch business/server.js",
    "pipeline": "cd data && python -m pipeline.scrape || (cd .. && python -m data.pipeline.scrape)",
    "pipeline:dry": "JAMMI_DRY_RUN=1 python -m data.pipeline.scrape",
    "pipeline:rescrape": "python -m data.pipeline.admin_rescrape",
    "pipeline:install": "pip install -r data/pipeline/requirements.txt"
  },
  "dependencies": {
    "express": "^4.19.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^12.6.0"
  },
  "keywords": [
    "uct",
    "jammie",
    "shuttle",
    "timetable",
    "cape-town"
  ],
  "license": "MIT"
}
